# Global environment for docker-compose.prod.yaml / Coolify

# Compose / infrastructure
APP_NAME=tasweeq
TZ=UTC
POSTGRES_DB=app_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
REDIS_PORT=6379
WEB_PORT=3001
WHATSAPP_SERVICE_PORT=4000
LOG_LEVEL=info
DEBUG=false

# Database URLs
# Shared DB access for db-migrate, db-seed, and whatsapp-service
DATABASE_URL=postgres://postgres:postgres@postgres:5432/app_db
# Web-only DB access, mapped into the web container as DATABASE_URL
DATABASE_URL_APPUSER=postgres://app_user:postgres@postgres:5432/app_db
POSTGRES_USER_ROLE=app_user

# Web app
BASE_URL=https://app.example.com
NEXT_PUBLIC_WEB_URL=https://app.example.com
# Keep this on the web domain so /socket.io stays proxied through Next.js
NEXT_PUBLIC_WEB_SOCKET=https://app.example.com
AUTH_SECRET=
ENCRYPTION_KEY=
RESEND_API_KEY=

# AWS / storage
AWS_REGION=
AWS_BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Meta app / embedded signup
M4D_APP_ID=
META_CLIENT_SECRET=
META_BUSINESS_ID=

# WhatsApp Cloud API used by the web app and bootstrap seed
WHATSAPP_API_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_WEBHOOK_SECRET=
WHATSAPP_API_VERSION=v22.0

# WhatsApp service
# Set to the public webhook verification token configured in Meta
WEBHOOK_VERIFICATION_TOKEN=
# If the service should use the same Cloud API token, copy the same value here
CLOUD_API_ACCESS_TOKEN=
GOOGLE_GENAI_API_KEY=
OPEN_AI_API_KEY=
OPEN_AI_ORG_ID=
OPEN_AI_PROJECT_ID=

# Optional first-load bootstrap seed values
DB_SEED_USER_EMAIL=owner@example.com
DB_SEED_USER_PASSWORD=ChangeMe123!
DB_SEED_USER_NAME=Company Owner
DB_SEED_TEAM_NAME=Company Name
DB_SEED_TEAM_SLUG=company-name
DB_SEED_TEAM_METADATA={"personal":false}
DB_SEED_TEAM_WHATSAPP_LIMIT=1000
DB_SEED_AD_ACCOUNT_ID=
